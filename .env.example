# ── Copy this file to .env and fill in your values ────────────────────────────

# App
LOG_LEVEL=INFO

# Firestore
GOOGLE_APPLICATION_CREDENTIALS=config/firestore_service_account.json
FIRESTORE_PROJECT_ID=your-gcp-project-id

# GEMMA / Ollama  (run: ollama serve && ollama pull gemma3:4b)
OLLAMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma3:4b
GEMMA_TEMPERATURE=0.7
GEMMA_MAX_TOKENS=2048

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store
FAISS_INDEX_PATH=data/faiss_index
TOP_K_RETRIEVAL=5

# Text splitting
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# API server
API_HOST=0.0.0.0
API_PORT=8000
