# ── Copy this file to .env and fill in your values ────────────────────────────

# App
LOG_LEVEL=INFO

# Firestore
# Set FIRESTORE_ENABLED=false to run without Firestore (local-only / dev mode).
# Sessions will be stored in-memory and documents won't be persisted remotely.
FIRESTORE_ENABLED=true
GOOGLE_APPLICATION_CREDENTIALS=config/firestore_service_account.json
FIRESTORE_PROJECT_ID=your-gcp-project-id

# Qwen / Ollama
# Start server: OLLAMA_NO_GPU=1 OLLAMA_LLM_LIBRARY=cpu ollama serve
# Pull model:   ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen:latest
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=180

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store
FAISS_INDEX_PATH=data/faiss_index
TOP_K_RETRIEVAL=5

# Text splitting
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# API server
API_HOST=0.0.0.0
API_PORT=8000
